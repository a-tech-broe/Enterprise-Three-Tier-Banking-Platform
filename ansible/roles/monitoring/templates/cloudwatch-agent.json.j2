{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "metrics": {
    "namespace": "{{ monitoring_cloudwatch_namespace }}",
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}"
    },
    "aggregation_dimensions": [["AutoScalingGroupName"]],
    "metrics_collected": {
      "cpu": {
        "measurement": ["cpu_usage_idle", "cpu_usage_iowait", "cpu_usage_user", "cpu_usage_system"],
        "totalcpu": true
      },
      "mem": { "measurement": ["mem_used_percent", "mem_available_percent"] },
      "disk": { "measurement": ["used_percent", "inodes_free"], "resources": ["/"] },
      "diskio": { "measurement": ["io_time"], "resources": ["*"] },
      "swap": { "measurement": ["swap_used_percent"] }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "{{ monitoring_app_log_file }}",
            "log_group_name": "{{ monitoring_cloudwatch_log_group }}",
            "log_stream_name": "{instance_id}/app",
            "retention_in_days": 90
          },
          {
            "file_path": "/var/log/messages",
            "log_group_name": "{{ monitoring_cloudwatch_log_group }}",
            "log_stream_name": "{instance_id}/system",
            "retention_in_days": 90
          }
        ]
      }
    }
  }
}
