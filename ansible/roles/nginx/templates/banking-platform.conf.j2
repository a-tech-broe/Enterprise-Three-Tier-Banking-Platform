# Managed by Ansible - banking-platform nginx role
upstream banking_app {
    server {{ nginx_upstream_host }}:{{ nginx_upstream_port }};
    keepalive 32;
}

server {
    listen {{ nginx_listen_port }};
    server_name {{ nginx_server_name }};

    # Lightweight health endpoint used by the ALB target group. Returns 200 even
    # before the application is deployed so the ASG can pass initial health checks.
    location = {{ nginx_health_path }} {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    location / {
        proxy_pass http://banking_app;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_connect_timeout 5s;
        proxy_read_timeout    60s;
        # Fail open to a maintenance response if the app is not yet up.
        proxy_intercept_errors on;
        error_page 502 503 504 = @maintenance;
    }

    location @maintenance {
        add_header Content-Type text/plain always;
        return 503 "banking-platform: application starting\n";
    }
}
